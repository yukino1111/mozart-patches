+int handleWord(buffer_handle_t handle, size_t byteOffset) {
+    return handle->data[(byteOffset - offsetof(native_handle_t, data)) / sizeof(int)];
+}
+
+bool isHisiHandle(buffer_handle_t handle) {
+    return handle != nullptr && handle->numFds >= 1 && handle->numInts >= 48 &&
+            static_cast<uint32_t>(handleWord(handle, 16)) == kHisiHandleMagic;
+}
+
+bool isYuvFormat(uint32_t format) {
+    return format >= HISI_FB_PIXEL_FORMAT_YUV_422_I &&
+            format <= HISI_FB_PIXEL_FORMAT_YCrCb_420_P;
+}
+
+bool convertHisiFormat(int halFormat, uint32_t* outFormat, uint32_t* outBpp) {
+    switch (halFormat) {
+        case HAL_PIXEL_FORMAT_RGBA_8888:
+            *outFormat = HISI_FB_PIXEL_FORMAT_RGBA_8888;
+            *outBpp = 4;
+            return true;
+        case HAL_PIXEL_FORMAT_RGBX_8888:
+            *outFormat = HISI_FB_PIXEL_FORMAT_RGBX_8888;
+            *outBpp = 4;
+            return true;
+        case HAL_PIXEL_FORMAT_RGB_565:
+            *outFormat = HISI_FB_PIXEL_FORMAT_RGB_565;
+            *outBpp = 2;
+            return true;
+        case HAL_PIXEL_FORMAT_BGRA_8888:
+            *outFormat = HISI_FB_PIXEL_FORMAT_BGRA_8888;
+            *outBpp = 4;
+            return true;
+        case HAL_PIXEL_FORMAT_YCbCr_422_SP:
+            *outFormat = HISI_FB_PIXEL_FORMAT_YCbCr_422_SP;
+            *outBpp = 2;
+            return true;
+        case HAL_PIXEL_FORMAT_YCrCb_420_SP:
+            *outFormat = HISI_FB_PIXEL_FORMAT_YCrCb_420_SP;
+            *outBpp = 1;
+            return true;
+        case 0x100:
+            *outFormat = HISI_FB_PIXEL_FORMAT_YCbCr_420_SP;
+            *outBpp = 1;
+            return true;
+        case 0x101:
+            *outFormat = HISI_FB_PIXEL_FORMAT_YCbCr_420_P;
+            *outBpp = 1;
+            return true;
+        case HAL_PIXEL_FORMAT_YV12:
+            *outFormat = HISI_FB_PIXEL_FORMAT_YCrCb_420_P;
+            *outBpp = 1;
+            return true;
+        default:
+            return false;
+    }
+}
+
+bool getHisiFormat(buffer_handle_t handle, uint32_t* outFormat) {
+    uint32_t bpp = 0;
+    return isHisiHandle(handle) && convertHisiFormat(handleWord(handle, 20), outFormat, &bpp);
+}
+
+uint32_t mapHwcTransform(int32_t transform) {
+    switch (transform) {
+        case HWC_TRANSFORM_FLIP_H:
+            return HISI_FB_TRANSFORM_FLIP_H;
+        case HWC_TRANSFORM_FLIP_V:
+            return HISI_FB_TRANSFORM_FLIP_V;
+        case HWC_TRANSFORM_ROT_90:
+            return HISI_FB_TRANSFORM_ROT_90;
+        case HWC_TRANSFORM_ROT_180:
+            return HISI_FB_TRANSFORM_ROT_180;
+        case HWC_TRANSFORM_ROT_270:
+            return HISI_FB_TRANSFORM_ROT_270;
+        default:
+            return HISI_FB_TRANSFORM_NOP;
+    }
+}
+
+int32_t mapHwcBlendMode(int32_t blendMode) {
+    switch (blendMode) {
+        case HWC2_BLEND_MODE_PREMULTIPLIED:
+            return HISI_FB_BLENDING_PREMULT;
+        case HWC2_BLEND_MODE_COVERAGE:
+            return HISI_FB_BLENDING_COVERAGE;
+        default:
+            return HISI_FB_BLENDING_NONE;
+    }
+}
+
+bool rectIsValid(const hwc_rect_t& rect) {
+    return rect.right > rect.left && rect.bottom > rect.top;
+}
+
+uint32_t rectWidth(const hwc_rect_t& rect) {
+    return static_cast<uint32_t>(rect.right - rect.left);
+}
+
+uint32_t rectHeight(const hwc_rect_t& rect) {
+    return static_cast<uint32_t>(rect.bottom - rect.top);
+}
+
+bool cropIsValid(const hwc_frect_t& crop) {
+    return crop.right > crop.left && crop.bottom > crop.top;
+}
+
+bool frameFitsDisplay(const hwc_rect_t& rect, const HWC2OnFbAdapter::Info& info) {
+    return rect.left >= 0 && rect.top >= 0 &&
+            rect.right <= static_cast<int32_t>(info.width) &&
+            rect.bottom <= static_cast<int32_t>(info.height);
+}
+
+uint64_t frameArea(const hwc_rect_t& rect) {
+    if (!rectIsValid(rect)) {
+        return 0;
+    }
+    return static_cast<uint64_t>(rectWidth(rect)) * rectHeight(rect);
+}
+
+uint32_t roundNonNegative(float value) {
+    return static_cast<uint32_t>(std::max(0.0f, std::round(value)));
+}
+
+bool fillDssLayer(buffer_handle_t handle, const hwc_frect_t& sourceCrop,
+                  const hwc_rect_t& displayFrame, int32_t blendMode, float planeAlpha,
+                  int32_t transform, int32_t layerIndex, int32_t channel, uint32_t needCap,
+                  dss_layer_t* outLayer) {
+    if (!isHisiHandle(handle) || !cropIsValid(sourceCrop) || !rectIsValid(displayFrame)) {
+        return false;
+    }
+
+    const uint32_t width = static_cast<uint32_t>(handleWord(handle, 88));
+    const uint32_t height = static_cast<uint32_t>(handleWord(handle, 92));
+    if (width == 0 || height == 0 || sourceCrop.left < 0.0f || sourceCrop.top < 0.0f ||
+            sourceCrop.right > static_cast<float>(width) ||
+            sourceCrop.bottom > static_cast<float>(height)) {
+        return false;
+    }
+
+    uint32_t hisiFormat = 0;
+    uint32_t bpp = 0;
+    if (!convertHisiFormat(handleWord(handle, 20), &hisiFormat, &bpp)) {
+        return false;
+    }
+
+    memset(outLayer, 0, sizeof(*outLayer));
+    outLayer->src.format = hisiFormat;
+    outLayer->src.width = width;
+    outLayer->src.height = height;
+    outLayer->src.bpp = bpp;
+    outLayer->src.stride = static_cast<uint32_t>(handleWord(handle, 32));
+    outLayer->src.uStride = static_cast<uint32_t>(handleWord(handle, 100));
+    outLayer->src.vStride = static_cast<uint32_t>(handleWord(handle, 104));
+    outLayer->src.buf_size = static_cast<uint32_t>(handleWord(handle, 120));
+    outLayer->src.phy_addr = static_cast<uint32_t>(handleWord(handle, 96));
+    outLayer->src.vir_addr = static_cast<uint32_t>(handleWord(handle, 116));
+    outLayer->src.uOffset = static_cast<uint32_t>(handleWord(handle, 108));
+    outLayer->src.vOffset = static_cast<uint32_t>(handleWord(handle, 112));
+    outLayer->src.ptba = static_cast<uint32_t>(handleWord(handle, 124));
+    outLayer->src.ptva = static_cast<uint32_t>(handleWord(handle, 128));
+    outLayer->src.is_tile = handleWord(handle, 132) == 1 ? 1 : 0;
+    outLayer->src.mmu_enable = outLayer->src.phy_addr == 0 ? 1 : 0;
+    outLayer->src.csc_mode = 0;
+    outLayer->src.secure_mode = 0;
+    outLayer->src.shared_fd = handle->data[0];
+
+    outLayer->src_rect.x = roundNonNegative(sourceCrop.left);
+    outLayer->src_rect.y = roundNonNegative(sourceCrop.top);
+    outLayer->src_rect.w = roundNonNegative(sourceCrop.right - sourceCrop.left);
+    outLayer->src_rect.h = roundNonNegative(sourceCrop.bottom - sourceCrop.top);
+
+    outLayer->dst_rect.x = static_cast<uint32_t>(displayFrame.left);
+    outLayer->dst_rect.y = static_cast<uint32_t>(displayFrame.top);
+    outLayer->dst_rect.w = rectWidth(displayFrame);
+    outLayer->dst_rect.h = rectHeight(displayFrame);
+
+    outLayer->transform = mapHwcTransform(transform);
+    outLayer->blending = mapHwcBlendMode(blendMode);
+    outLayer->glb_alpha = static_cast<uint32_t>(std::max(0.0f, std::min(1.0f, planeAlpha)) * 255.0f);
+    outLayer->layer_idx = layerIndex;
+    outLayer->chn_idx = channel;
+    outLayer->need_cap = needCap;
+    if (isYuvFormat(hisiFormat)) {
+        outLayer->need_cap |= CAP_CSC;
+    }
+    if (outLayer->src_rect.w != outLayer->dst_rect.w ||
+            outLayer->src_rect.h != outLayer->dst_rect.h) {
+        outLayer->need_cap |= CAP_SCL;
+    }
+    outLayer->flags = DSS_SCENE_PDP_ONLINE;
+    outLayer->acquire_fence = -1;
+    return true;
+}
