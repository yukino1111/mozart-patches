+}
+
+const std::unordered_set<hwc2_layer_t>& HWC2OnFbAdapter::getClearClientTargetLayers() const {
+    return mClearClientTargetLayers;
+}
+
+void HWC2OnFbAdapter::acceptChanges() {
+    for (auto& entry : mLayerStates) {
+        entry.second.requestedType = entry.second.validatedType;
+    }
+    mChangedTypes.clear();
 }
 
