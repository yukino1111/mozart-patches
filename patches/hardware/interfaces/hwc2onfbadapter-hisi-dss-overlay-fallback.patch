+bool HWC2OnFbAdapter::postOverlay() {
+    if (!mHasOverlayLayer || mOverlayDisabledByError) {
+        return false;
+    }
+
+    auto it = mLayerStates.find(mOverlayLayer);
+    if (it == mLayerStates.end()) {
+        return false;
+    }
+
+    if (mOverlayUsesClientTarget && !mBuffer) {
+        ALOGE("mozart DSS overlay needs client target, but none was provided");
+        mOverlayDisabledByError = true;
+        mHasOverlayLayer = false;
+        mOverlayUsesClientTarget = false;
+        setState(State::MODIFIED);
+        return false;
+    }
+
+    dss_overlay_t overlay;
+    memset(&overlay, 0, sizeof(overlay));
+    overlay.release_fence = -1;
+    overlay.wb_layer_info.acquire_fence = -1;
+    overlay.wb_layer_info.release_fence = -1;
+    overlay.ovl_flags = DSS_SCENE_PDP_ONLINE;
+    overlay.dirty_region_updt_info.dirty_rect.x = 0;
+    overlay.dirty_region_updt_info.dirty_rect.y = 0;
+    overlay.dirty_region_updt_info.dirty_rect.w = mFbInfo.width;
+    overlay.dirty_region_updt_info.dirty_rect.h = mFbInfo.height;
+
+    uint32_t layerCount = 0;
+    const auto& video = it->second;
+    if (!fillDssLayer(video.buffer, video.sourceCrop, video.displayFrame,
+                      HWC2_BLEND_MODE_NONE, 1.0f, video.transform, layerCount,
+                      DPE0_CHN0, CAP_DMA, &overlay.layer_infos[layerCount])) {
+        ALOGE("mozart DSS overlay video layer became invalid");
+        mOverlayDisabledByError = true;
+        mHasOverlayLayer = false;
+        mOverlayUsesClientTarget = false;
+        setState(State::MODIFIED);
+        return false;
+    }
+    layerCount++;
+
+    if (mOverlayUsesClientTarget) {
+        const hwc_frect_t clientCrop{0.0f, 0.0f, static_cast<float>(mFbInfo.width),
+                                     static_cast<float>(mFbInfo.height)};
+        const hwc_rect_t clientFrame{0, 0, static_cast<int32_t>(mFbInfo.width),
+                                     static_cast<int32_t>(mFbInfo.height)};
+        if (!fillDssLayer(mBuffer, clientCrop, clientFrame, HWC2_BLEND_MODE_PREMULTIPLIED,
+                          1.0f, 0, layerCount, DPE0_CHN3, CAP_FB_POST,
+                          &overlay.layer_infos[layerCount])) {
+            ALOGE("mozart DSS overlay client target became invalid");
+            mOverlayDisabledByError = true;
+            mHasOverlayLayer = false;
+            mOverlayUsesClientTarget = false;
+            setState(State::MODIFIED);
+            return false;
+        }
+        layerCount++;
+    }
+
+    overlay.layer_nums = layerCount;
+
+    int fbFd = open("/dev/graphics/fb0", O_RDWR | O_CLOEXEC);
+    if (fbFd < 0) {
+        ALOGE("mozart DSS overlay open fb0 failed: %s", strerror(errno));
+        mOverlayDisabledByError = true;
+        mHasOverlayLayer = false;
+        mOverlayUsesClientTarget = false;
+        setState(State::MODIFIED);
+        return false;
+    }
+
+    if (ioctl(fbFd, HISIFB_OV_ONLINE_PLAY, &overlay) != 0) {
+        const int savedErrno = errno;
+        ALOGE("mozart DSS overlay ioctl failed: %s", strerror(savedErrno));
+        ::close(fbFd);
+        if (overlay.release_fence >= 0) {
+            ::close(overlay.release_fence);
+        }
+        mOverlayDisabledByError = true;
+        mHasOverlayLayer = false;
+        mOverlayUsesClientTarget = false;
+        setState(State::MODIFIED);
+        return false;
+    }
+
+    ::close(fbFd);
+    if (overlay.release_fence >= 0) {
+        ::close(overlay.release_fence);
+    }
+    return true;
+}
