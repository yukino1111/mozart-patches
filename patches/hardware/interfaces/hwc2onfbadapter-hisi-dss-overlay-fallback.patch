+void HWC2OnFbAdapter::validateLayers(uint32_t* outNumTypes, uint32_t* outNumRequests) {
+    mChangedTypes.clear();
+    mClearClientTargetLayers.clear();
+    mHasOverlayLayer = false;
+    mOverlayUsesClientTarget = false;
+
+    const bool wasEnabled = mOverlayEnabled;
+    mOverlayEnabled = property_get_bool("persist.debug.mozart.hwc_overlay", false);
+    if (!mOverlayEnabled) {
+        mOverlayDisabledByError = false;
+    } else if (!wasEnabled) {
+        ALOGI("mozart DSS overlay fallback enabled");
+    }
+
+    hwc2_layer_t overlayLayer = 0;
+    uint64_t overlayArea = 0;
+    if (mOverlayEnabled && !mOverlayDisabledByError) {
+        for (const auto& entry : mLayerStates) {
+            const auto& state = entry.second;
+            uint32_t hisiFormat = 0;
+            dss_layer_t testLayer;
+            if (state.requestedType != HWC2_COMPOSITION_DEVICE ||
+                    state.transform != 0 ||
+                    state.planeAlpha < 0.999f ||
+                    !rectIsValid(state.displayFrame) ||
+                    !frameFitsDisplay(state.displayFrame, mFbInfo) ||
+                    !cropIsValid(state.sourceCrop) ||
+                    !getHisiFormat(state.buffer, &hisiFormat) ||
+                    !isYuvFormat(hisiFormat) ||
+                    !fillDssLayer(state.buffer, state.sourceCrop, state.displayFrame,
+                                  HWC2_BLEND_MODE_NONE, 1.0f, state.transform, 0,
+                                  DPE0_CHN0, CAP_DMA, &testLayer)) {
+                continue;
+            }
+
+            uint64_t area = frameArea(state.displayFrame);
+            if (area > overlayArea) {
+                overlayArea = area;
+                overlayLayer = entry.first;
+            }
+        }
+    }
+
+    bool hasClientComposition = false;
+    for (auto& entry : mLayerStates) {
+        auto& state = entry.second;
+        const int32_t validatedType =
+                overlayLayer != 0 && entry.first == overlayLayer
+                        ? HWC2_COMPOSITION_DEVICE
+                        : HWC2_COMPOSITION_CLIENT;
+
+        state.validatedType = validatedType;
+        if (state.requestedType != validatedType) {
+            mChangedTypes.emplace(entry.first, validatedType);
+        }
+        if (validatedType == HWC2_COMPOSITION_CLIENT) {
+            hasClientComposition = true;
+        }
+    }
+
+    if (overlayLayer != 0) {
+        mHasOverlayLayer = true;
+        mOverlayLayer = overlayLayer;
+        if (hasClientComposition) {
+            mOverlayUsesClientTarget = true;
+            mClearClientTargetLayers.insert(overlayLayer);
+        }
+    }
+
+    *outNumTypes = mChangedTypes.size();
+    *outNumRequests = mClearClientTargetLayers.size();
+}
+
+const std::unordered_map<hwc2_layer_t, int32_t>& HWC2OnFbAdapter::getChangedTypes() const {
